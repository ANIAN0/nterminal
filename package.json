{
  "name": "nterminal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node server.mjs",
    "build": "next build",
    "start": "cross-env NODE_ENV=production node server.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run test/backend/unit",
    "test:integration": "vitest run test/backend/integration test/frontend/integration",
    "test:component": "vitest run test/frontend/component",
    "test:smoke": "vitest run test/smoke",
    "test:e2e": "playwright test test/e2e",
    "test:performance": "playwright test test/performance",
    "verify": "npm test && npm run lint && npm run build"
  },
  "dependencies": {
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@wterm/core": "^0.3.0",
    "@wterm/react": "^0.3.0",
    "@xterm/headless": "^5.5.0",
    "ai": "^6.0.208",
    "better-sqlite3": "^11.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.7",
    "node-pty": "^1.1.0",
    "proper-lockfile": "^4.1.2",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "shiki": "^4.2.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.6",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
